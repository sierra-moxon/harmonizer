# Keep the Docker build context lean: exclude local dev state, caches, and any
# artifacts that would otherwise bloat the context or leak into images.

# Python virtualenv / caches
.venv/
**/__pycache__/
**/*.pyc
.pytest_cache/
.ruff_cache/
.mypy_cache/

# Local databases and job outputs (mounted at runtime, never baked in)
*.db
jobs/
data/

# VCS / editor / CI
.git/
.gitignore
.github/

# Build output
dist/
build/
*.egg-info/

# Docs and evaluations (not needed in images)
docs/
evaluations/
IMPLEMENTATION_PLAN.md

# Environment / secrets (never copy credentials into an image)
.env
.env.*
